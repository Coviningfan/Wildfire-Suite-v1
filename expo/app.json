{
  "expo": {
    "name": "Wildfire Suite",
    "slug": "wildfire-suite",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wildfire-suite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wildfirelighting.suite"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wildfirelighting.suite"
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://wildfirelighting.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Wildfire uses the camera to scan fixture QR codes."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Wildfire uses Face ID to securely sign you in."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}